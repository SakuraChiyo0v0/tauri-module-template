{
  "schemaVersion": 1,
  "id": "starter-module",
  "name": "Starter Module",
  "description": "Business-neutral standalone runtime module starter.",
  "version": "0.1.0",
  "hostVersion": ">=0.2.0, <0.3.0",
  "sdkVersion": 3,
  "entry": "index.js",
  "dependencies": {
    "required": [],
    "optional": []
  },
  "navigation": [
    {
      "id": "starter-module-home",
      "title": "Starter Module",
      "description": "Standalone runtime module development check.",
      "element": "starter-module-page",
      "group": "main",
      "order": 200
    }
  ],
  "settings": [
    {
      "id": "showDetails",
      "type": "switch",
      "group": "starter-module",
      "order": 10,
      "label": "Show module details",
      "description": "Updates the module page through namespaced Host SDK settings.",
      "defaultValue": true
    }
  ],
  "nativeCapabilities": {
    "filesystem": { "private": true, "external": ["read", "write", "list"] },
    "process": { "urlSchemes": ["https"], "executableGrants": true },
    "registry": [],
    "tray": [
      { "id": "open-main", "label": "Open module", "kind": "button", "order": 10 }
    ],
    "shortcuts": [
      { "id": "show-main", "description": "Show the module page", "accelerator": "Ctrl+Shift+M" }
    ]
  }
}
